{
  "comment": "ECS Task Definition для visual-inspection-service на AWS Fargate. Замени ACCOUNT_ID и ENDPOINT на реальные значения.",

  "family": "visual-inspection-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],

  "cpu": "512",
  "memory": "1024",

  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",

  "containerDefinitions": [
    {
      "name": "api",
      "image": "ACCOUNT_ID.dkr.ecr.eu-west-1.amazonaws.com/visual-inspection-service:latest",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],

      "environment": [
        {
          "name": "REDIS_URL",
          "value": "redis://YOUR_ELASTICACHE_ENDPOINT:6379/0"
        },
        {
          "name": "MLFLOW_TRACKING_URI",
          "value": "http://YOUR_MLFLOW_HOST:5000"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/visual-inspection-service",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "ecs"
        }
      },

      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
